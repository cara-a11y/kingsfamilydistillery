<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Spirits – King's Family Distillery</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --black: #0a0906;
      --brass: #b7a173;
      --brass-light: #d4bc93;
      --brass-dim: #7a6a4a;
      --offwhite: #f0ebe0;
      --text-muted: #8a7a60;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--black);
      color: var(--offwhite);
      font-family: 'EB Garamond', Georgia, serif;
      font-size: 17px;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      text-align: center;
      padding: 56px 24px 40px;
      border-bottom: 1px solid var(--brass-dim);
      position: relative;
    }

    .header-logo {
      display: block;
      width: clamp(120px, 22vw, 180px);
      margin: 0 auto 12px;
    }

    .logo-sub {
      font-family: 'Cinzel', serif;
      font-weight: 400;
      font-size: clamp(0.65rem, 1.8vw, 0.8rem);
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--brass-dim);
    }

    .header-rule {
      width: 48px;
      height: 1px;
      background: var(--brass);
      margin: 20px auto 16px;
    }

    .header-tagline {
      font-family: 'EB Garamond', serif;
      font-style: italic;
      font-size: clamp(0.85rem, 2vw, 1rem);
      color: var(--text-muted);
      letter-spacing: 0.04em;
    }

    /* ── INTRO ── */
    .intro {
      text-align: center;
      padding: 44px 24px 32px;
      max-width: 600px;
      margin: 0 auto;
    }

    .intro h1 {
      font-family: 'Cinzel', serif;
      font-weight: 600;
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      color: var(--brass);
      letter-spacing: 0.08em;
      line-height: 1.25;
      margin-bottom: 16px;
    }

    .intro p {
      color: var(--text-muted);
      font-size: 1rem;
      font-style: italic;
    }

    .caveat {
      margin-top: 12px;
      font-size: 0.78rem;
      color: #5a5040;
      font-style: italic;
      border-top: 1px solid #2a2318;
      padding-top: 12px;
    }

    /* ── NAV TABS ── */
    .category-nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      padding: 0 20px 36px;
      max-width: 780px;
      margin: 0 auto;
    }

    .cat-tab {
      font-family: 'Cinzel', serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--brass-dim);
      background: transparent;
      border: 1px solid var(--brass-dim);
      padding: 8px 16px;
      cursor: pointer;
      transition: all 0.2s ease;
      border-radius: 0;
      white-space: nowrap;
    }

    .cat-tab:hover,
    .cat-tab.active {
      background: var(--brass);
      color: var(--black);
      border-color: var(--brass);
    }

    /* ── CATEGORY SECTIONS ── */
    .spirits-wrapper {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 20px 80px;
    }

    .category-section {
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .category-section.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .category-header {
      text-align: center;
      margin-bottom: 32px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--brass-dim);
    }

    .category-header h2 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.4rem, 3.5vw, 2rem);
      font-weight: 600;
      color: var(--brass);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .category-header p {
      font-style: italic;
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-top: 8px;
    }

    /* ── SPIRIT CARD ── */
    .spirit-card {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: start;
      gap: 12px 20px;
      padding: 24px 0;
      border-bottom: 1px solid #1f1c16;
    }

    .spirit-card:last-child {
      border-bottom: none;
    }

    .spirit-name {
      font-family: 'Cinzel', serif;
      font-size: clamp(0.9rem, 2.2vw, 1.1rem);
      font-weight: 600;
      color: var(--offwhite);
      letter-spacing: 0.08em;
      line-height: 1.3;
    }

    .spirit-desc {
      font-size: 0.92rem;
      color: var(--text-muted);
      font-style: italic;
      margin-top: 5px;
      line-height: 1.55;
    }

    .spirit-awards {
      margin-top: 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .award-badge {
      font-family: 'Cinzel', serif;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--brass);
      border: 1px solid var(--brass-dim);
      padding: 2px 7px;
      white-space: nowrap;
    }

    .spirit-meta {
      text-align: right;
      white-space: nowrap;
    }

    .proof-tag {
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brass-dim);
    }

    .availability {
      display: block;
      font-family: 'Cinzel', serif;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 5px;
      padding: 2px 8px;
      text-align: center;
    }

    .avail-instore { color: var(--brass); border: 1px solid var(--brass-dim); }
    .avail-online  { color: #7ec88a; border: 1px solid #3a6040; }
    .avail-both    { color: var(--brass-light); border: 1px solid var(--brass-dim); }
    .avail-limited { color: #c8a87e; border: 1px solid #5a4020; }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 36px 24px 48px;
      border-top: 1px solid var(--brass-dim);
    }

    .footer-logo {
      font-family: 'Cinzel', serif;
      font-size: 0.75rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--brass-dim);
      margin-bottom: 10px;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .footer-links a {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--brass-dim);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--brass); }

    .disclaimer {
      margin-top: 20px;
      font-size: 0.75rem;
      color: #3a3428;
      font-style: italic;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 520px) {
      .spirit-card {
        grid-template-columns: 1fr;
      }
      .spirit-meta {
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
      }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <img src="data:image/png;base64," alt="King's Family Distillery" class="header-logo" />
    <span class="logo-sub">Sevierville &amp; Pigeon Forge, Tennessee</span>
    <div class="header-rule"></div>
    <p class="header-tagline">Handcrafted in the heart of the Smoky Mountains</p>
  </header>

  <!-- INTRO -->
  <div class="intro">
    <h1>Our Spirits</h1>
    <p>Explore our full lineup of award-winning small-batch spirits — something for every palate. Enjoy up to 10 complimentary samples when you visit.</p>
    <p class="caveat">Our selection changes frequently. This list may be incomplete and availability varies by location and season. Ask your guide what's pouring today.</p>
  </div>

  <!-- CATEGORY NAVIGATION -->
  <nav class="category-nav" aria-label="Spirit categories">
    <button class="cat-tab active" onclick="showCategory('bourbon')">Bourbon</button>
    <button class="cat-tab" onclick="showCategory('whiskey')">Whiskey &amp; Rye</button>
    <button class="cat-tab" onclick="showCategory('flavored-whiskey')">Flavored Whiskey</button>
    <button class="cat-tab" onclick="showCategory('vodka')">Vodka &amp; Gin</button>
    <button class="cat-tab" onclick="showCategory('rum')">Rum</button>
    <button class="cat-tab" onclick="showCategory('cream')">Cream &amp; Moonshine</button>
  </nav>

  <!-- SPIRITS CONTENT -->
  <div class="spirits-wrapper">

    <!-- BOURBON -->
    <section class="category-section active" id="bourbon">
      <div class="category-header">
        <h2>Bourbon</h2>
        <p>Single barrel expressions &amp; small-batch blends aged 6–11 years in charred oak</p>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Bourbon</div>
          <div class="spirit-desc">Big and bold — smoky tobacco, vanilla, sweet raisin and fig. Single barrel, high corn mash bill, aged at least 6 years.</div>
          <div class="spirit-awards">
            <span class="award-badge">Double Gold – SF World Spirits</span>
            <span class="award-badge">Best in Show – Great American Spirits</span>
            <span class="award-badge">Double Gold – Fifty Best Bourbons</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">87 / 107 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Tennessee Standard Bourbon</div>
          <div class="spirit-desc">Pronounced butterscotch and good decisions. 99% corn mash bill blended with aged light whiskey, aged at least 6 years.</div>
          <div class="spirit-awards">
            <span class="award-badge">Gold – Fifty Best Bourbon</span>
            <span class="award-badge">Gold – SF World Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Available In Store</span>
          <span class="availability avail-instore">In Store</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Wheated Bourbon</div>
          <div class="spirit-desc">Subtle and earthy — caramel, butterscotch, cinnamon, soft wheaty finish. A great choice for fans of Maker's or the Weller lineup.</div>
          <div class="spirit-awards">
            <span class="award-badge">Double Gold – NY Wine &amp; Spirits</span>
            <span class="award-badge">Gold – Fifty Best Bourbon</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">100 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Toasted Agave Bourbon</div>
          <div class="spirit-desc">Bourbon finished in an agave-toasted barrel. Light sweetness on the back end with a 36% rye mash bill for depth.</div>
          <div class="spirit-awards">
            <span class="award-badge">Silver – South's Best Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Barrel Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Honey Bourbon</div>
          <div class="spirit-desc">Classic bourbon richness with a sweet honey finish — aged in a cask previously used to age honey. Limited releases.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">110 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Bourbon 10</div>
          <div class="spirit-desc">A decade of aging — caramel, vanilla, smooth indulgent sweetness with subtle earthy balance. Crafted as a special anniversary edition.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">105 Proof · 11 Yr</span>
          <span class="availability avail-limited">Limited</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Cigar Blend</div>
          <div class="spirit-desc">A blend of Port Wine, Sherry, and Madeira cask-finished bourbons. Intense, layered, and deeply complex.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Cask Strength</span>
          <span class="availability avail-instore">In Store Only</span>
        </div>
      </div>

    </section>

    <!-- WHISKEY & RYE -->
    <section class="category-section" id="whiskey">
      <div class="category-header">
        <h2>Whiskey &amp; Rye</h2>
        <p>From our flagship Ryeconic to rare single barrel expressions — bold, complex, and celebrated</p>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Ryeconic</div>
          <div class="spirit-desc">Our signature top-shelf rye — aged in two separate barrels, 95% rye mash bill. One of our most decorated bottles.</div>
          <div class="spirit-awards">
            <span class="award-badge">Best of Show – North American B&amp;W</span>
            <span class="award-badge">Double Gold – SF World Spirits</span>
            <span class="award-badge">Double Gold – Fifty Best Ryes</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">105 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Rye</div>
          <div class="spirit-desc">Dark chocolate, licorice, toasted tobacco, hazelnut, and cherry. Classic rye spice with a clean, robust finish.</div>
          <div class="spirit-awards">
            <span class="award-badge">Double Platinum – Ascot Awards</span>
            <span class="award-badge">Double Gold – SF World Spirits</span>
            <span class="award-badge">Double Gold – Fifty Best Ryes</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">90 Proof · 4 Yr</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Toasted Ryeconic</div>
          <div class="spirit-desc">Spice and cinnamon forward, with caramel and toasted oak. Triple-oaked with a six-hour char flash toast on the third barrel.</div>
          <div class="spirit-awards">
            <span class="award-badge">Gold – North American B&amp;W</span>
            <span class="award-badge">Double Gold – SF World Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Cask Strength · 9 Yr</span>
          <span class="availability avail-instore">In Store Only</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Honey Ryeconic</div>
          <div class="spirit-desc">Twice-barreled Ryeconic finished in a local East Tennessee honey cask. The honey tames the spice — rich sweetness on the back.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Barrel Proof</span>
          <span class="availability avail-online">Online Only</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Ryeconic Cherry Brandy Cask Finish</div>
          <div class="spirit-desc">Signature Ryeconic spice mellowed with sweetness — candied cherry finish. Doesn't drink cask strength, but it is.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Cask Strength</span>
          <span class="availability avail-instore">In Store Only</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Toasted Amburana Rye</div>
          <div class="spirit-desc">Our twice-barreled rye finished in a toasted amburana barrel — warm, spiced, and distinctly layered.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Cask Strength</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's American Blended Whiskey</div>
          <div class="spirit-desc">Light and sweet — honey, caramel, vanilla, nutmeg, and pear. A blend of bourbon and light whiskey aged at least 7 years.</div>
          <div class="spirit-awards">
            <span class="award-badge">Gold – Fifty Best American Blended</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">80 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Reserve</div>
          <div class="spirit-desc">Tennessee Whiskey aged 8 years in its original barrel, then rested 1 year in a sweet vermouth cask. A distillery exclusive sipper.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Cask Strength</span>
          <span class="availability avail-instore">In Store Only</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's High Proof Whiskey</div>
          <div class="spirit-desc">Aged 10 years, bottled at a powerful 155 proof. Unfiltered and uncompromising. Best enjoyed slowly.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">155 Proof · 10 Yr</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

    </section>

    <!-- FLAVORED WHISKEY -->
    <section class="category-section" id="flavored-whiskey">
      <div class="category-header">
        <h2>Flavored Whiskey</h2>
        <p>Real fruit, real flavors — approachable, smooth, and made for everyone</p>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Apple Whiskey</div>
          <div class="spirit-desc">Butter smooth with sweet hints of vanilla and cinnamon, finishing with smoky caramel. Made with two-year whiskey and natural apple flavor.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Blackberry Whiskey</div>
          <div class="spirit-desc">Deep rose hue, all blackberry with a subtle hint of whiskey. Blended with real blackberry juice and just a touch of cane sugar.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Peach Whiskey</div>
          <div class="spirit-desc">Light, sweet, and oh so peachy. Blended with real peach juice — amazingly versatile. Try it with iced tea or ginger ale.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Chocolate Whiskey</div>
          <div class="spirit-desc">Tastes like a chocolate mousse that can get you in just enough trouble. Natural chocolate flavor with cane sugar — smooth and decadent.</div>
          <div class="spirit-awards">
            <span class="award-badge">Bronze – SF World Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Cinnamon Whiskey</div>
          <div class="spirit-desc">Steeped with real cinnamon sticks for natural cinnamon flavor — no artificial shortcuts, just the right amount of warmth and spice.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

    </section>

    <!-- VODKA & GIN -->
    <section class="category-section" id="vodka">
      <div class="category-header">
        <h2>Vodka &amp; Gin</h2>
        <p>Clean, crafted, and award-winning — made from 100% US-grown corn, naturally gluten-free</p>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Vodka</div>
          <div class="spirit-desc">Uniquely smooth and velvety with a clean finish. Made from 100% US-grown corn — non-GMO and naturally gluten-free.</div>
          <div class="spirit-awards">
            <span class="award-badge">Silver – Fifty Best Domestic Vodkas</span>
            <span class="award-badge">Bronze – Great American Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">80 Proof</span>
          <span class="availability avail-instore">In Store Only</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Ginger Vodka</div>
          <div class="spirit-desc">Spicy, sweet, and refreshing — honey, grapefruit, lavender, and fresh ginger. Made from our 6x distilled corn vodka.</div>
          <div class="spirit-awards">
            <span class="award-badge">Gold – Barleycorn Awards</span>
            <span class="award-badge">Bronze – SF World Spirits</span>
          </div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">61 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Lemon Vodka</div>
          <div class="spirit-desc">Back by popular demand. A splash of bright lemon flavor — perfect in iced tea, fruit juice, soda, or paired with King's Blackberry.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">Available In Store</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

      <div class="spirit-card">
        <div>
          <div class="spirit-name">King's Gin</div>
          <div class="spirit-desc">Juniper on the nose, star anise forward on the palate, with a sweet and floral finish. A gin for the non-gin drinker — citrusy and refreshing.</div>
        </div>
        <div class="spirit-meta">
          <span class="proof-tag">80 Proof</span>
          <span class="availability avail-both">In Store &amp; Online</span>
        </div>
      </div>

    </section>

    <!-- RUM -->
